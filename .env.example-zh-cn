# utips 开源部署环境变量示例。
# 运行 Docker Compose 前，请复制为 .env：
#   cp .env.example-zh-cn .env

# 已发布的一体化镜像。如果要本地构建，请改用 compose.build.yaml。
DOCKER_IMAGE=uzqw/utips:latest
DOCKER_CONTAINER_NAME=utips
# 服务会监听 0.0.0.0，方便局域网内其它设备访问。
# 端口规划：前端开发 17170，后端开发 17171，Docker 一体化服务 17172。
DOCKER_HOST_PORT=17172

# Linux 宿主机目录挂载时，容器进程需要有写入权限。
# 建议设置为宿主机当前用户的 UID/GID，可通过 `id -u` 和 `id -g` 查看。
APP_UID=1000
APP_GID=1000

# 宿主机上的数据目录，用于保存 PocketBase SQLite 数据库和上传文件。
# 升级时请保持这个路径不变；如果从其它安装迁移，请先把旧数据目录复制到这里。
DOCKER_UNOTES_DATA_PATH=./unotes_data

# 后端容器运行时使用的时区。留空则默认使用系统/宿主机时区。
TZ=

# 登录页底部显示的备案号。留空则不显示备案号。
UTIPS_ICP_BEIAN_NUMBER=

# 管理员邮箱，会显示在找回密码页面和相关帮助文案里。
UTIPS_ADMIN_EMAIL=admin@example.com

# 演示账号配置。启用后，项目初始化时会自动把该账号加入数据库，并在登录页显示“试用演示账户”。
# 公开部署前请务必修改默认密码，或者把 UTIPS_DEMO_ACCOUNT_ENABLED 改为 false。
UTIPS_DEMO_ACCOUNT_ENABLED=true
UTIPS_DEMO_ACCOUNT_EMAIL=demo@example.com
UTIPS_DEMO_ACCOUNT_PASSWORD=demo123456
UTIPS_DEMO_ACCOUNT_NAME=演示账号
