# utips open-source deployment example.
# Copy this file to .env before running Docker Compose:
#   cp .env.example .env

# Published all-in-one image. For local builds use compose.build.yaml instead.
DOCKER_IMAGE=uzqw/utips:latest
DOCKER_CONTAINER_NAME=utips
# Services bind to 0.0.0.0 for cross-device LAN access.
# Port plan: frontend dev 17170, backend dev 17171, Docker all-in-one 17172.
DOCKER_HOST_PORT=17172

# Linux bind mounts must be writable by the container process.
# Set these to your host user id/group id (`id -u` and `id -g`).
APP_UID=1000
APP_GID=1000

# Host directory that stores PocketBase SQLite files and uploaded files.
# Keep this path stable across upgrades. Copy an existing PocketBase data
# directory here before starting if you are migrating from another install.
DOCKER_UNOTES_DATA_PATH=./unotes_data

# Runtime timezone used by the backend container. Leave empty to use system/host timezone.
TZ=

# ICP filing number shown on the login page footer. Leave empty to hide it.
UTIPS_ICP_BEIAN_NUMBER=

# Admin email shown on the password recovery page and related help text.
UTIPS_ADMIN_EMAIL=admin@example.com

# Demo account shown on the login page and created during project initialization.
# Change the password before exposing a public deployment, or set enabled to false.
UTIPS_DEMO_ACCOUNT_ENABLED=true
UTIPS_DEMO_ACCOUNT_EMAIL=demo@example.com
UTIPS_DEMO_ACCOUNT_PASSWORD=demo123456
UTIPS_DEMO_ACCOUNT_NAME=Demo Account
